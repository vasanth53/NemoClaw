{
  "name": "nemoclaw",
  "version": "0.1.0",
  "description": "NemoClaw — run OpenClaw inside OpenShell with NVIDIA inference",
  "license": "Apache-2.0",
  "bin": {
    "nemoclaw": "./bin/nemoclaw.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "prepare": "husky || true",
    "prepublishOnly": "cd nemoclaw && env -u npm_config_global -u npm_config_prefix -u npm_config_omit npm install --ignore-scripts && ./node_modules/.bin/tsc"
  },
  "dependencies": {
    "openclaw": "2026.3.11"
  },
  "files": [
    "bin/",
    "nemoclaw/dist/",
    "nemoclaw/openclaw.plugin.json",
    "nemoclaw/package.json",
    "nemoclaw-blueprint/",
    "scripts/",
    "Dockerfile",
    ".dockerignore"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NVIDIA/NemoClaw.git"
  },
  "lint-staged": {
    "nemoclaw/src/**/*.ts": [
      "bash scripts/check-spdx-headers.sh",
      "sh -c 'cd nemoclaw && npx eslint --fix \"$@\"' _",
      "sh -c 'cd nemoclaw && npx prettier --write \"$@\"' _"
    ],
    "nemoclaw-blueprint/**/*.py": [
      "bash scripts/check-spdx-headers.sh",
      "uvx ruff check --fix",
      "uvx ruff format"
    ],
    "**/*.sh": [
      "bash scripts/check-spdx-headers.sh",
      "npx shellcheck"
    ],
    ".husky/{pre-commit,pre-push,commit-msg}": "npx shellcheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "shellcheck": "^4.1.0"
  }
}
